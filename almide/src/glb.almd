module glb

import json
import bytes
import fs

let GLB_MAGIC = 0x46546C67
let CHUNK_JSON = 0x4E4F534A
let CHUNK_BIN = 0x004E4942

type GlbFile = {
  json_data: json.Value,
  bin_data: Bytes,
}

// ---- Load ----

effect fn load(path: String) -> Result[GlbFile, String] = {
  let data = match fs.read_bytes_raw(path) {
    ok(d) => d,
    err(e) => err(e),
  }
  parse(data)
}

fn parse(data: Bytes) -> Result[GlbFile, String] = {
  guard bytes.len(data) >= 12 else err("too small")

  let magic = bytes.read_u32_le(data, 0)
  guard magic == GLB_MAGIC else err("not GLB")

  let total_length = bytes.read_u32_le(data, 8)

  var offset = 12
  var json_val: Option[json.Value] = none
  var bin_bytes: Bytes = bytes.new(0)

  while offset + 8 <= int.min(total_length, bytes.len(data)) {
    let chunk_len = bytes.read_u32_le(data, offset)
    let chunk_type = bytes.read_u32_le(data, offset + 4)
    offset = offset + 8
    let end = int.min(offset + chunk_len, bytes.len(data))

    if chunk_type == CHUNK_JSON then {
      let json_str = bytes.to_string_lossy(bytes.slice(data, offset, end))
      match json.parse(json_str) {
        ok(v) => { json_val = some(v) },
        err(_) => {},
      }
    } else if chunk_type == CHUNK_BIN then {
      bin_bytes = bytes.slice(data, offset, end)
    } else {}

    offset = end
  }

  match json_val {
    some(j) => ok(GlbFile { json_data: j, bin_data: bin_bytes }),
    none => err("no JSON chunk"),
  }
}

// ---- Save ----

effect fn save(glb: GlbFile, path: String) -> Result[Unit, String] = {
  let json_str = json.stringify(glb.json_data)
  let json_bytes = bytes.from_string(json_str)

  let json_pad = (4 - bytes.len(json_bytes) % 4) % 4
  let json_padded = if json_pad > 0 then bytes.concat(json_bytes, bytes.from_string(string.repeat(" ", json_pad))) else json_bytes
  let json_len = bytes.len(json_padded)

  let has_bin = bytes.len(glb.bin_data) > 0
  let bin_pad = if has_bin then (4 - bytes.len(glb.bin_data) % 4) % 4 else 0
  let bin_total = if has_bin then bytes.len(glb.bin_data) + bin_pad else 0

  let total = 12 + 8 + json_len + (if has_bin then 8 + bin_total else 0)

  let out = bytes.new(0)

  bytes.append_u32_le(out, GLB_MAGIC)
  bytes.append_u32_le(out, 2)
  bytes.append_u32_le(out, total)

  bytes.append_u32_le(out, json_len)
  bytes.append_u32_le(out, CHUNK_JSON)
  // Append json_padded byte by byte
  var i = 0
  while i < bytes.len(json_padded) {
    bytes.push(out, bytes.get_or(json_padded, i, 0))
    i = i + 1
  }

  if has_bin then {
    bytes.append_u32_le(out, bin_total)
    bytes.append_u32_le(out, CHUNK_BIN)
    var j = 0
    while j < bytes.len(glb.bin_data) {
      bytes.push(out, bytes.get_or(glb.bin_data, j, 0))
      j = j + 1
    }
    var k = 0
    while k < bin_pad {
      bytes.push(out, 0)
      k = k + 1
    }
  } else {}

  fs.write_bytes_raw(path, out)
}

// ---- Image operations ----

fn extract_image(glb: GlbFile, image_index: Int) -> Result[Bytes, String] = {
  let images = match json.get_array(glb.json_data, "images") {
    some(i) => i,
    none => err("no images"),
  }
  let img = match list.get(images, image_index) {
    some(i) => i,
    none => err("image index out of range"),
  }
  let bv_idx = match json.get_int(img, "bufferView") {
    some(i) => i,
    none => err("no bufferView"),
  }
  let bvs = match json.get_array(glb.json_data, "bufferViews") {
    some(b) => b,
    none => err("no bufferViews"),
  }
  let bv = match list.get(bvs, bv_idx) {
    some(b) => b,
    none => err("bufferView out of range"),
  }
  let offset = option.unwrap_or(json.get_int(bv, "byteOffset"), 0)
  let length = match json.get_int(bv, "byteLength") {
    some(l) => l,
    none => err("no byteLength"),
  }
  ok(bytes.slice(glb.bin_data, offset, offset + length))
}

// ---- Tests ----

test "parse rejects too-small data" {
  let data = bytes.from_list([0, 0, 0])
  match parse(data) {
    err(_) => {},
    _ => assert_eq(true, false),
  }
}
